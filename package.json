{
  "name": "tpt-emergency",
  "version": "1.0.0",
  "description": "Modular Emergency Services System",
  "license": "MIT",
  "author": "TPT Emergency Services",
  "repository": {
    "type": "git",
    "url": "https://github.com/TPT-Open-Source/tpt-emergency"
  },
  "homepage": "https://github.com/TPT-Open-Source/tpt-emergency",
  "bugs": {
    "url": "https://github.com/TPT-Open-Source/tpt-emergency/issues"
  },
  "main": "server/index.js",
  "bin": "server/index.cjs",
  "type": "module",
  "pkg": {
    "assets": [
      "dist/assets/**/*",
      "dist/index.html",
      "dist/manifest.webmanifest",
      "dist/registerSW.js",
      "dist/sw.js",
      "dist/workbox-*.js",
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "scripts": [
      "node_modules/socket.io/**/*.js",
      "node_modules/socket.io-adapter/**/*.js",
      "node_modules/socket.io-parser/**/*.js",
      "node_modules/engine.io/**/*.js",
      "node_modules/engine.io-parser/**/*.js"
    ],
    "targets": [
      "node22-win-x64",
      "node22-macos-x64",
      "node22-linux-x64"
    ],
    "outputPath": "dist/bin"
  },
  "scripts": {
    "dev": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "build": "vite build",
    "build:exe": "pkg . --out-path dist/bin",
    "build:all": "npm run build && npm run build:exe",
    "build:singlehtml": "vite build --mode singlefile",
    "docker:build": "docker build -t tpt-emergency .",
    "docker:run": "docker run -p 3000:3000 -v ./data:/app/data tpt-emergency",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@maplibre/maplibre-gl-geocoder": "^1.9.4",
    "better-sqlite3": "^9.4.0",
    "dexie": "^3.2.5",
    "fastify": "^5.8.5",
    "fastify-socket.io": "^4.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0",
    "autoprefixer": "^10.4.17",
    "maplibre-gl": "^4.0.0",
    "pkg": "^5.8.1",
    "postcss": "^8.4.33",
    "solid-js": "^1.8.11",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.9.1",
    "vitest": "^4.1.5",
    "workbox-core": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0"
  }
}
